

// Operator precedence
$counter = 1 || 2 && 3 == 4 + 5 * -(6 + 7)

// function declaration
function add($a, $b) {
    return $a + $b
}

// loop
while $counter < 10 {
    // piped command with redirects
    cat test | cat > res.txt | cat &> res2.txt

    // function call
    $counter = $counter + $(add 1 2)
}
