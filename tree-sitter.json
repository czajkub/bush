      },
      {
        "name": "Jakub Czyż, Jakub Czajka",
        "email": "jczyz@student.agh.edu.pl"
      }
    ],
    "links": {
      "repository": "https://github.com/czajkub/bush"
    }
  },
  "bindings": {
    "c": false,
    "go": true,
    "java": false,
    "node": false,
